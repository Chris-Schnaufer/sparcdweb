[req]
distinguished_name  = req_distinguished_name
x509_extensions     = v3_req
prompt              = no

[req_distinguished_name]
C       = US
ST      = Arizona
L       = Tucson
O       = University of Arizona
CN      = localhost

[v3_req]
subjectAltName = @alt_names

[alt_names]
DNS.1   = localhost
DNS.2   = sparcd
DNS.3   = sparcd.arizona.edu
IP.1    = 127.0.0.1
IP.2    = 128.196.254.96